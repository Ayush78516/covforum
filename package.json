{
  "name": "internship-root",
  "version": "1.0.0",
  "description": "Root folder for internship project",
  "scripts": {
    "front-build": "npm run build --prefix front",
    "backend": "npm start --prefix Internship-project",
    "dev": "npm run backend",
    "build": "npm install && npm install --prefix front && npm install --prefix Internship-project && npm run front-build",
    "start": "npm run backend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
